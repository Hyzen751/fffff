local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local CoreGui = game:GetService("CoreGui")
local StarterGui = game:GetService("StarterGui")

local LocalPlayer = Players.LocalPlayer

local UILib = loadstring(game:HttpGet("https://raw.githubusercontent.com/Hyzen751/fffff/main/uilib.lua"))()
if not UILib then
    return
end

local Window = UILib:Create({
    Name = "Wave | Flee The Facility 10 Player",
    ThemeColor = Color3.fromRGB(45, 11, 11),
    ThemeGradient = Color3.fromRGB(11, 22, 66),
    StartupSound = "rbxassetid://6958727243",
    ThemeFont = Enum.Font.GothamBold,
    ToggledSideBar = true
})

local ESPTab = Window:Tab("ESP")
local InfoTab = Window:Tab("Info")

ESPTab:Label("ESP Features")
InfoTab:Label("Made for 10 Player Flee")

local PlayerESPEnabled = false
local ComputerESPEnabled = false
local PodESPEnabled = false

local function notify(title, text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = 3
        })
    end)
end

local function clearByName(name)
    for _, v in ipairs(CoreGui:GetDescendants()) do
        if v.Name == name then
            v:Destroy()
        end
    end

    for _, v in ipairs(Workspace:GetDescendants()) do
        if v.Name == name then
            v:Destroy()
        end
    end
end

local function addHighlight(target, name, color)
    if not target then
        return
    end

    local old = target:FindFirstChild(name)
    if old then
        old:Destroy()
    end

    local h = Instance.new("Highlight")
    h.Name = name
    h.Adornee = target
    h.FillColor = color
    h.OutlineColor = Color3.fromRGB(255, 255, 255)
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Parent = target
end

local function refreshPlayerESP()
    clearByName("WavePlayerESP")

    if not PlayerESPEnabled then
        return
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            addHighlight(plr.Character, "WavePlayerESP", Color3.fromRGB(0, 255, 255))
        end
    end
end

local function refreshComputerESP()
    clearByName("WaveComputerESP")

    if not ComputerESPEnabled then
        return
    end

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and (obj.Name == "ComputerTable" or obj.Name == "Computer") then
            addHighlight(obj, "WaveComputerESP", Color3.fromRGB(0, 255, 170))
        end
    end
end

local function refreshPodESP()
    clearByName("WavePodESP")

    if not PodESPEnabled then
        return
    end

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and (obj.Name == "FreezePod" or obj.Name == "Pod") then
            addHighlight(obj, "WavePodESP", Color3.fromRGB(170, 85, 255))
        end
    end
end

ESPTab:Toggle("Player ESP", function()
    PlayerESPEnabled = not PlayerESPEnabled
    notify("Player ESP", PlayerESPEnabled and "Enabled" or "Disabled")
    refreshPlayerESP()
end)

ESPTab:Toggle("Computer ESP", function()
    ComputerESPEnabled = not ComputerESPEnabled
    notify("Computer ESP", ComputerESPEnabled and "Enabled" or "Disabled")
    refreshComputerESP()
end)

ESPTab:Toggle("Freeze Pod ESP", function()
    PodESPEnabled = not PodESPEnabled
    notify("Freeze Pod ESP", PodESPEnabled and "Enabled" or "Disabled")
    refreshPodESP()
end)

for _, plr in ipairs(Players:GetPlayers()) do
    plr.CharacterAdded:Connect(function()
        task.wait(1)
        refreshPlayerESP()
    end)
end

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        task.wait(1)
        refreshPlayerESP()
    end)
end)

Workspace.DescendantAdded:Connect(function()
    task.wait(0.5)
    refreshComputerESP()
    refreshPodESP()
end)
