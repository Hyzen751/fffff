	exitESPEnabled = not exitESPEnabled
	notify("Exit-Door ESP", exitESPEnabled and "Enabled." or "Disabled.")

	for _, model in ipairs(Workspace:GetDescendants()) do
		if model:IsA("Model") and model.Name == "ExitDoor" then
