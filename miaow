		btn.Text = soundName .. " | " .. parentName
		btn.TextWrapped = true
		btn.LayoutOrder = i
		btn.ZIndex = 11
		btn.Parent = SoundList

		local lastClick = 0
		btn.MouseButton1Click:Connect(function()
			local now = tick()
			if now - lastClick < 0.4 then
				-- Double clic = spam
