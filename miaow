local http = request({
    Url = "https://raw.githubusercontent.com/Hyzen751/fffff/main/uilib.lua",
    Method = "GET"
})

if not http or http.StatusCode ~= 200 or not http.Body or http.Body == "" then
    return
end

local Library = loadstring(http.Body)()
if not Library then
    return
end

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local StarterGui = game:GetService("StarterGui")

local LocalPlayer = Players.LocalPlayer

local Window = Library:Create({
    Name = "Wave | FTF 10 Player",
    ThemeColor = Color3.fromRGB(45, 11, 11),
    ThemeGradient = Color3.fromRGB(11, 22, 66),
    StartupSound = "rbxassetid://6958727243",
    ThemeFont = Enum.Font.GothamBold,
    ToggledSideBar = true
})

local MainTab = Window:Tab("Main")
local ESPTab = Window:Tab("ESP")
local InfoTab = Window:Tab("Info")

MainTab:Label("Flee The Facility 10 Player")
InfoTab:Label("ESP séparé pour Players / Beast / Computers / Pods")

local Flags = {
    PlayerESP = false,
    BeastESP = false,
    ComputerESP = false,
    PodESP = false
}

local function notify(title, text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = 3
        })
    end)
end

local function clearTag(tag)
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Highlight") and obj.Name == tag then
            obj:Destroy()
        end
    end
end

local function getCharacterRoot(character)
    return character:FindFirstChild("HumanoidRootPart")
        or character:FindFirstChild("UpperTorso")
        or character:FindFirstChild("Torso")
        or character.PrimaryPart
end

local function isBeast(plr)
    if not plr then
        return false
    end

    local role = plr:GetAttribute("Role")
    if tostring(role):lower() == "beast" then
        return true
    end

    local stats = plr:FindFirstChild("TempPlayerStats")
    if stats and stats:FindFirstChild("IsBeast") then
        return stats.IsBeast.Value == true
    end

    local flag = plr:FindFirstChild("IsBeast")
    if flag then
        return flag.Value == true
    end

    return false
end

local function addHighlight(target, tag, color)
    if not target then
        return
    end

    local old = target:FindFirstChild(tag)
    if old then
        old:Destroy()
    end

    local h = Instance.new("Highlight")
    h.Name = tag
    h.Adornee = target
    h.FillColor = color
    h.OutlineColor = Color3.fromRGB(255, 255, 255)
    h.FillTransparency = 0.35
    h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Parent = target
end

local function refreshPlayers()
    clearTag("Wave_PlayerESP")
    clearTag("Wave_BeastESP")

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            if isBeast(plr) then
                if Flags.BeastESP then
                    addHighlight(plr.Character, "Wave_BeastESP", Color3.fromRGB(255, 70, 70))
                end
            else
                if Flags.PlayerESP then
                    addHighlight(plr.Character, "Wave_PlayerESP", Color3.fromRGB(0, 200, 255))
                end
            end
        end
    end
end

local function looksLikeComputer(obj)
    local n = obj.Name:lower()
    return n == "computertable" or n == "computer" or n:find("computer") or n:find("pc")
end

local function looksLikePod(obj)
    local n = obj.Name:lower()
    return n == "freezepod" or n == "pod" or n:find("freeze") or n:find("pod")
end

local function refreshComputers()
    clearTag("Wave_ComputerESP")

    if not Flags.ComputerESP then
        return
    end

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and looksLikeComputer(obj) then
            addHighlight(obj, "Wave_ComputerESP", Color3.fromRGB(0, 255, 170))
        end
    end
end

local function refreshPods()
    clearTag("Wave_PodESP")

    if not Flags.PodESP then
        return
    end

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and looksLikePod(obj) then
            addHighlight(obj, "Wave_PodESP", Color3.fromRGB(170, 85, 255))
        end
    end
end

local function refreshAll()
    refreshPlayers()
    refreshComputers()
    refreshPods()
end

ESPTab:Label("Visuals")

ESPTab:Toggle("Player ESP", function()
    Flags.PlayerESP = not Flags.PlayerESP
    notify("Player ESP", Flags.PlayerESP and "Enabled" or "Disabled")
    refreshPlayers()
end)

ESPTab:Toggle("Beast ESP", function()
    Flags.BeastESP = not Flags.BeastESP
    notify("Beast ESP", Flags.BeastESP and "Enabled" or "Disabled")
    refreshPlayers()
end)

ESPTab:Toggle("Computer ESP", function()
    Flags.ComputerESP = not Flags.ComputerESP
    notify("Computer ESP", Flags.ComputerESP and "Enabled" or "Disabled")
    refreshComputers()
end)

ESPTab:Toggle("Freeze Pod ESP", function()
    Flags.PodESP = not Flags.PodESP
    notify("Freeze Pod ESP", Flags.PodESP and "Enabled" or "Disabled")
    refreshPods()
end)

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        task.wait(1)
        refreshPlayers()
    end)
end)

for _, plr in ipairs(Players:GetPlayers()) do
    plr.CharacterAdded:Connect(function()
        task.wait(1)
        refreshPlayers()
    end)
end

Workspace.DescendantAdded:Connect(function(obj)
    task.wait(0.25)

    if obj:IsA("Model") then
        if Flags.ComputerESP and looksLikeComputer(obj) then
            addHighlight(obj, "Wave_ComputerESP", Color3.fromRGB(0, 255, 170))
        end

        if Flags.PodESP and looksLikePod(obj) then
            addHighlight(obj, "Wave_PodESP", Color3.fromRGB(170, 85, 255))
        end
    end
end)

task.spawn(function()
    while task.wait(2) do
        refreshAll()
    end
end)

notify("Wave", "FTF 10 Player loaded")
