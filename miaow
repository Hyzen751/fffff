	for _, obj in next, workspace:GetDescendants() do
		if obj:IsA("Sound") and obj.SoundId ~= "" then
			local ok = pcall(function()
				obj:Play()
				obj:Stop()
			end)
			if ok then
				table.insert(sons, obj)
			end
		end
	end

	if #sons == 0 then
		game:GetService("StarterGui"):SetCore("SendNotification", {
			Title = "Sons", Text = "Aucun son jouable trouvé!", Duration = 3,
		})
		return
	end

	game:GetService("StarterGui"):SetCore("SendNotification", {
		Title = "Sons trouvés", Text = #sons .. " sons jouables!", Duration = 3,
	})

	for i, sound in ipairs(sons) do
		local soundId = sound.SoundId
		local soundName = sound.Name
		local parentName = sound.Parent and sound.Parent.Name or "?"

		local btn = Instance.new("TextButton")
