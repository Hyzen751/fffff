local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local player = Players.LocalPlayer

-- Config
local DEFLECT_ZONE = 15 -- distance autour de toi
local HOTKEY = Enum.KeyCode.E -- touche pour activer/desactiver
local autoDeflectEnabled = false

-- GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "AutoDeflectGUI"
ScreenGui.Parent = game:GetService("CoreGui")
ScreenGui.ResetOnSpawn = false

local Frame = Instance.new("Frame")
Frame.Parent = ScreenGui
Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Frame.BorderSizePixel = 0
Frame.Position = UDim2.new(0.01, 0, 0.4, 0)
Frame.Size = UDim2.new(0, 200, 0, 80)
Frame.Active = true
Frame.Draggable = true

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = Frame

local StatusLabel = Instance.new("TextLabel")
StatusLabel.Parent = Frame
StatusLabel.BackgroundTransparency = 1
StatusLabel.Position = UDim2.new(0, 0, 0, 5)
StatusLabel.Size = UDim2.new(1, 0, 0, 30)
StatusLabel.Font = Enum.Font.GothamBold
StatusLabel.Text = "Auto Deflect"
StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
StatusLabel.TextSize = 16

local ToggleBtn = Instance.new("TextButton")
ToggleBtn.Parent = Frame
ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
ToggleBtn.BorderSizePixel = 0
ToggleBtn.Position = UDim2.new(0.1, 0, 0, 40)
ToggleBtn.Size = UDim2.new(0.8, 0, 0, 30)
ToggleBtn.Font = Enum.Font.GothamBold
ToggleBtn.Text = "OFF  [E]"
ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleBtn.TextSize = 14

local UICorner2 = Instance.new("UICorner")
UICorner2.CornerRadius = UDim.new(0, 6)
UICorner2.Parent = ToggleBtn

-- Fonction toggle
local function toggle()
    autoDeflectEnabled = not autoDeflectEnabled
    if autoDeflectEnabled then
        ToggleBtn.Text = "ON  [E]"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        StatusLabel.TextColor3 = Color3.fromRGB(50, 255, 50)
    else
        ToggleBtn.Text = "OFF  [E]"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        StatusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    end
end

ToggleBtn.MouseButton1Click:Connect(toggle)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == HOTKEY then
        toggle()
    end
end)

-- Trouve la balle
local function findBall()
    for _, obj in next, workspace:GetDescendants() do
        if obj:IsA("BasePart") then
            local name = obj.Name:lower()
            if name:find("ball") or name:find("deathball") or name:find("projectile") then
                return obj
            end
        end
    end
    return nil
end

-- Trouve le RemoteEvent pour deflect
local function findDeflectRemote()
    local rs = game:GetService("ReplicatedStorage")
    for _, obj in next, rs:GetDescendants() do
        if obj:IsA("RemoteEvent") then
            local name = obj.Name:lower()
            if name:find("parry") or name:find("deflect") or name:find("block") or name:find("swing") then
                return obj
            end
        end
    end
    return nil
end

-- Simule le click M1 pour deflect
local function doDeflect()
    -- Méthode 1: via RemoteEvent
    local remote = findDeflectRemote()
    if remote then
        pcall(function()
            remote:FireServer()
        end)
    end
    
    -- Méthode 2: simule le clic souris
    pcall(function()
        local mouse = player:GetMouse()
        mouse1click()
    end)
end

local lastDeflect = 0

-- Loop principal
RunService.Heartbeat:Connect(function()
    if not autoDeflectEnabled then return end
    
    local char = player.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local ball = findBall()
    if not ball then return end
    
    local dist = (ball.Position - root.Position).Magnitude
    
    -- Zone de deflect
    if dist <= DEFLECT_ZONE then
        local now = tick()
        if now - lastDeflect > 0.3 then -- cooldown pour pas spammer
            lastDeflect = now
            doDeflect()
        end
    end
end)
